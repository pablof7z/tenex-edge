#!/usr/bin/env bash
set -euo pipefail

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

quote_cmd() {
  printf '%q ' "$@"
}

backend_command_for_profile() {
  case "$1" in
    claude*) echo "claude" ;;
    codex-ollama*) echo "codex-ollama" ;;
    codex*) echo "codex" ;;
    opencode-ollama*) echo "opencode-ollama" ;;
    opencode*) echo "opencode" ;;
    *) echo "$1" ;;
  esac
}

agent_slug_for_profile() {
  case "$1" in
    claude*) echo "claude" ;;
    codex*) echo "codex" ;;
    opencode*) echo "opencode" ;;
    *) echo "$1" ;;
  esac
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
if [[ $# -lt 3 ]]; then
  echo "usage: $0 <lab.env> <direct|launch> <profile> [agent args...]" >&2
  exit 2
fi

ENV_FILE="$1"
MODE="$2"
PROFILE="$3"
if [[ ! -f "${ENV_FILE}" ]]; then
  echo "usage: $0 <lab.env> <direct|launch> <profile> [agent args...]" >&2
  exit 2
fi
shift 3
# shellcheck source=/dev/null
source "${ENV_FILE}"

SESSION="${TENEX_EDGE_DEV_AGENT_SESSION:-te-${MODE}-${PROFILE}-${RUN_ID}}"
BACKEND_CMD="${TENEX_EDGE_DEV_BACKEND_CMD:-$(backend_command_for_profile "${PROFILE}")}"
AGENT_SLUG="${TENEX_EDGE_DEV_AGENT_SLUG:-$(agent_slug_for_profile "${PROFILE}")}"
CONTAINER_NAME="${TENEX_EDGE_DEV_CONTAINER_NAME:-${SESSION}}"
CONTAINER_CIDFILE="${WORK_DIR}/container-${SESSION}.cid"

case "${MODE}" in
  direct)
    cmd=(env TENEX_EDGE_CONTAINER_NAME="${CONTAINER_NAME}" TENEX_EDGE_CONTAINER_CIDFILE="${CONTAINER_CIDFILE}" bash containers/tenex-edge/run --profile "${PROFILE}" "${BACKEND_CMD}" "$@")
    ;;
  launch)
    cmd=(env TENEX_EDGE_CONTAINER_NAME="${CONTAINER_NAME}" TENEX_EDGE_CONTAINER_CIDFILE="${CONTAINER_CIDFILE}" bash containers/tenex-edge/run --profile "${PROFILE}" tenex-edge launch "${AGENT_SLUG}" -- "$@")
    ;;
  *)
    echo "unknown mode: ${MODE}" >&2
    exit 2
    ;;
esac

echo "agent_session=${SESSION}"
echo "mode=${MODE}"
echo "profile=${PROFILE}"
echo "backend_command=${BACKEND_CMD}"
echo "agent_slug=${AGENT_SLUG}"
echo "container_name=${CONTAINER_NAME}"
echo "container_cidfile=${CONTAINER_CIDFILE}"
cd "${REPO_ROOT}"
exec "${cmd[@]}"
