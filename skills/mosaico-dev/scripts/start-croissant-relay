#!/usr/bin/env bash
set -euo pipefail

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

quote_env() {
  local key="$1" value="$2"
  printf '%s=%q\n' "$key" "$value"
}

relay_host() {
  local host=""
  if command -v container >/dev/null 2>&1 && container system status >/dev/null 2>&1; then
    host="$(container network inspect default 2>/dev/null \
      | jq -er '.[0].status.ipv4Gateway // empty' 2>/dev/null || true)"
  fi
  if [[ -z "${host}" ]]; then
    host="$(ipconfig getifaddr bridge100 2>/dev/null || true)"
  fi
  printf '%s\n' "${host:-127.0.0.1}"
}

pick_port() {
  local start="${MOSAICO_DEV_RELAY_PORT_BASE:-19888}"
  local limit="${MOSAICO_DEV_RELAY_PORT_LIMIT:-200}"
  local port end
  end=$((start + limit))
  for ((port = start; port < end; port++)); do
    if ! lsof -nP -tiTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1; then
      printf '%s\n' "${port}"
      return 0
    fi
  done
  echo "no free relay port found in ${start}..$((end - 1))" >&2
  return 1
}

wait_for_relay() {
  local http="$1"
  local timeout="${2:-20}"
  local start now
  start="$(date +%s)"
  while true; do
    if curl -fsS -H 'Accept: application/nostr+json' "$http" >/dev/null 2>&1; then
      return 0
    fi
    now="$(date +%s)"
    if (( now - start >= timeout )); then
      return 1
    fi
    sleep 1
  done
}

stop_relay() {
  local pid
  [[ -s "${RELAY_PID_FILE:-}" ]] || return 0
  pid="$(cat "${RELAY_PID_FILE}")"
  if kill -0 "${pid}" 2>/dev/null; then
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
  fi
}

need curl
need jq
need lsof
need nak

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

RUN_ID="${MOSAICO_DEV_RUN_ID:-$(date +%Y%m%d-%H%M%S)}"
RELAY_HOST="${MOSAICO_DEV_RELAY_HOST:-$(relay_host)}"
RELAY_BIND_HOST="${MOSAICO_DEV_RELAY_BIND_HOST:-${RELAY_HOST}}"
RELAY_PORT="${MOSAICO_DEV_RELAY_PORT:-$(pick_port)}"
RELAY_WS="ws://${RELAY_HOST}:${RELAY_PORT}"
RELAY_HTTP="http://${RELAY_HOST}:${RELAY_PORT}"
WORK_DIR="${MOSAICO_DEV_WORK:-${TMPDIR:-/tmp}/mosaico-live-lab-${RUN_ID}}"
RELAY_DATA="${WORK_DIR}/relay-data"
RELAY_PID_FILE="${WORK_DIR}/relay.pid"
RELAY_LOG="${WORK_DIR}/relay.log"
ENV_FILE="${WORK_DIR}/lab.env"
MOSAICO_BIN="${MOSAICO_DEV_MOSAICO_BIN:-${REPO_ROOT}/target/debug/mosaico}"
CROISSANT_BIN="${MOSAICO_DEV_CROISSANT_BIN:-${NIP29_RELAY_BIN:-$(command -v croissant 2>/dev/null || true)}}"

if [[ ! -x "${MOSAICO_BIN}" ]]; then
  need cargo
  (cd "${REPO_ROOT}" && cargo build --bin mosaico)
fi
if [[ -z "${CROISSANT_BIN}" || ! -x "${CROISSANT_BIN}" ]]; then
  echo "Croissant is external infrastructure; set MOSAICO_DEV_CROISSANT_BIN or NIP29_RELAY_BIN" >&2
  exit 1
fi

if [[ -f "${RELAY_PID_FILE}" ]] && kill -0 "$(cat "${RELAY_PID_FILE}")" 2>/dev/null; then
  echo "relay process already exists: $(cat "${RELAY_PID_FILE}")" >&2
  exit 1
fi

listener_pid="$(lsof -nP -tiTCP:"${RELAY_PORT}" -sTCP:LISTEN 2>/dev/null | head -1 || true)"
if [[ -n "${listener_pid}" ]]; then
  echo "port ${RELAY_PORT} is already held by pid ${listener_pid}" >&2
  exit 1
fi

mkdir -p "${RELAY_DATA}" "${WORK_DIR}/keys"
OWNER_SK_FILE="${WORK_DIR}/keys/relay-owner.nsec"
if [[ ! -s "${OWNER_SK_FILE}" ]]; then
  nak key generate >"${OWNER_SK_FILE}"
  chmod 600 "${OWNER_SK_FILE}"
fi
OWNER_PK="$(nak key public "$(cat "${OWNER_SK_FILE}")")"
HUMAN_NAMES_JSON="${MOSAICO_DEV_HUMAN_NAMES_JSON:-[\"operator\"]}"
if ! jq -e 'type == "array" and length > 0 and
  all(.[]; type == "string" and length > 0) and
  (unique | length) == length' <<<"${HUMAN_NAMES_JSON}" >/dev/null; then
  echo "MOSAICO_DEV_HUMAN_NAMES_JSON must be a non-empty array of unique names" >&2
  exit 2
fi
HUMAN_IDENTITIES_FILE="${WORK_DIR}/humans.json"
human_identities='[]'
human_count="$(jq 'length' <<<"${HUMAN_NAMES_JSON}")"
for ((i = 0; i < human_count; i++)); do
  human_number=$((i + 1))
  human_name="$(jq -r ".[${i}]" <<<"${HUMAN_NAMES_JSON}")"
  if ((i == 0)); then
    human_key_file="${OWNER_SK_FILE}"
  else
    human_key_file="${WORK_DIR}/keys/human-${human_number}.nsec"
    if [[ ! -s "${human_key_file}" ]]; then
      nak key generate >"${human_key_file}"
      chmod 600 "${human_key_file}"
    fi
  fi
  human_pubkey="$(nak key public "$(<"${human_key_file}")")"
  human_identities="$(jq -cn \
    --argjson identities "${human_identities}" \
    --argjson number "${human_number}" \
    --arg name "${human_name}" \
    --arg pubkey "${human_pubkey}" \
    --arg secret_file "${human_key_file}" \
    '$identities + [{number:$number,name:$name,pubkey:$pubkey,secret_file:$secret_file}]')"
done
if [[ "$(jq '[.[].pubkey] | unique | length' <<<"${human_identities}")" != "${human_count}" ]]; then
  echo "generated human identities do not have distinct pubkeys" >&2
  exit 1
fi
printf '%s\n' "${human_identities}" >"${HUMAN_IDENTITIES_FILE}"
chmod 600 "${HUMAN_IDENTITIES_FILE}"

(
  cd "${WORK_DIR}"
  exec nohup env \
    HOST="${RELAY_BIND_HOST}" \
    PORT="${RELAY_PORT}" \
    DATAPATH="${RELAY_DATA}" \
    DOMAIN="" \
    OWNER_PUBLIC_KEY="${OWNER_PK}" \
    "${CROISSANT_BIN}"
) >"${RELAY_LOG}" 2>&1 &
echo "$!" >"${RELAY_PID_FILE}"

if ! wait_for_relay "${RELAY_HTTP}" "${MOSAICO_DEV_RELAY_READY_TIMEOUT:-20}"; then
  stop_relay
  tail -80 "${RELAY_LOG}" >&2 || true
  echo "relay did not become ready: ${RELAY_HTTP}" >&2
  exit 1
fi
if ! kill -0 "$(cat "${RELAY_PID_FILE}")" 2>/dev/null; then
  tail -80 "${RELAY_LOG}" >&2 || true
  echo "relay exited immediately after readiness: ${RELAY_HTTP}" >&2
  exit 1
fi

{
  quote_env RUN_ID "${RUN_ID}"
  quote_env REPO_ROOT "${REPO_ROOT}"
  quote_env MOSAICO_BIN "${MOSAICO_BIN}"
  quote_env CROISSANT_BIN "${CROISSANT_BIN}"
  quote_env WORK_DIR "${WORK_DIR}"
  quote_env RELAY_BIND_HOST "${RELAY_BIND_HOST}"
  quote_env RELAY_HOST "${RELAY_HOST}"
  quote_env RELAY_PORT "${RELAY_PORT}"
  quote_env RELAY_WS "${RELAY_WS}"
  quote_env RELAY_HTTP "${RELAY_HTTP}"
  quote_env RELAY_DATA "${RELAY_DATA}"
  quote_env RELAY_PID_FILE "${RELAY_PID_FILE}"
  quote_env RELAY_LOG "${RELAY_LOG}"
  quote_env OWNER_PUBLIC_KEY "${OWNER_PK}"
  quote_env OWNER_SK_FILE "${OWNER_SK_FILE}"
  quote_env HUMAN_IDENTITIES_FILE "${HUMAN_IDENTITIES_FILE}"
} >"${ENV_FILE}"

echo "run_id=${RUN_ID}"
echo "env=${ENV_FILE}"
echo "relay=${RELAY_WS}"
echo "relay_pid=$(cat "${RELAY_PID_FILE}")"
echo "owner_pubkey=${OWNER_PK:0:12}"
echo "human_count=${human_count}"

if [[ "${MOSAICO_DEV_RELAY_FOREGROUND:-0}" == "1" ]]; then
  echo "relay_foreground=1"
  wait "$(cat "${RELAY_PID_FILE}")" || true
fi
