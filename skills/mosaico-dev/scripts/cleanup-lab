#!/usr/bin/env bash
set -euo pipefail

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

stop_container() {
  local id="$1"
  [[ -n "${id}" ]] || return 0
  if ! command -v container >/dev/null 2>&1; then
    return 0
  fi
  if container inspect "${id}" >/dev/null 2>&1; then
    container stop "${id}" >/dev/null 2>&1 || container kill "${id}" >/dev/null 2>&1 || true
    container rm "${id}" >/dev/null 2>&1 || true
    echo "container_stopped=${id}"
  fi
}

ENV_FILE="${1:-${MOSAICO_DEV_ENV:-}}"
if [[ -z "${ENV_FILE}" || ! -f "${ENV_FILE}" ]]; then
  echo "usage: $0 <lab.env> [container-id ...]" >&2
  exit 2
fi
shift || true
# shellcheck source=/dev/null
source "${ENV_FILE}"

for container_id in "$@"; do
  stop_container "${container_id}"
done

for cidfile in "${WORK_DIR}"/container-*.cid; do
  [[ -f "${cidfile}" ]] || continue
  stop_container "$(cat "${cidfile}")"
done

if [[ -n "${RELAY_PID_FILE:-}" && -f "${RELAY_PID_FILE}" ]]; then
  relay_pid="$(cat "${RELAY_PID_FILE}")"
  if kill -0 "${relay_pid}" 2>/dev/null; then
    kill "${relay_pid}" 2>/dev/null || true
    echo "relay_stopped=${relay_pid}"
  fi
fi
