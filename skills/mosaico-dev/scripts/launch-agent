#!/usr/bin/env bash
set -euo pipefail

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

quote_cmd() {
  printf '%q ' "$@"
}

backend_command_for_profile() {
  case "$1" in
    claude*) echo "claude" ;;
    codex-ollama*) echo "codex-ollama" ;;
    codex*) echo "codex" ;;
    grok*) echo "grok" ;;
    goose*) echo "goose" ;;
    opencode-ollama*) echo "opencode-ollama" ;;
    opencode*) echo "opencode" ;;
    *) echo "$1" ;;
  esac
}

agent_slug_for_profile() {
  case "$1" in
    claude*) echo "claude" ;;
    codex*) echo "codex" ;;
    grok*) echo "grok" ;;
    goose*) echo "goose" ;;
    opencode*) echo "opencode" ;;
    *) echo "$1" ;;
  esac
}

need jq

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
if [[ $# -lt 3 ]]; then
  echo "usage: $0 <lab.env> <direct|smoke|launch> <profile> [args...]" >&2
  exit 2
fi

ENV_FILE="$1"
MODE="$2"
PROFILE="$3"
if [[ ! -f "${ENV_FILE}" ]]; then
  echo "usage: $0 <lab.env> <direct|smoke|launch> <profile> [args...]" >&2
  exit 2
fi
shift 3
# shellcheck source=/dev/null
source "${ENV_FILE}"

SESSION="${MOSAICO_DEV_AGENT_SESSION:-mosaico-${MODE}-${PROFILE}-${RUN_ID}}"
BACKEND_CMD="${MOSAICO_DEV_BACKEND_CMD:-$(backend_command_for_profile "${PROFILE}")}"
AGENT_SLUG="${MOSAICO_DEV_AGENT_SLUG:-$(agent_slug_for_profile "${PROFILE}")}"
CONTAINER_NAME="${MOSAICO_DEV_CONTAINER_NAME:-${SESSION}}"
CONTAINER_CIDFILE="${WORK_DIR}/container-${SESSION}.cid"
STATE_ROOT="${MOSAICO_DEV_STATE_ROOT:-${REPO_ROOT}/.container-state}"
STATE_DIR="${MOSAICO_CONTAINER_STATE:-${STATE_ROOT}/${PROFILE}}"
AGENT_CFG="${STATE_DIR}/mosaico/agents/${AGENT_SLUG}.json"
HARNESSES_CFG="${STATE_DIR}/mosaico/harnesses.json"

if [[ ! -f "${AGENT_CFG}" || ! -f "${HARNESSES_CFG}" ]]; then
  printf 'profile %s has no generated harness/agent config; run write-container-profiles first\n' "${PROFILE}" >&2
  exit 2
fi
BUNDLE="$(jq -er '.harness' "${AGENT_CFG}")"
TRANSPORT="$(jq -er --arg bundle "${BUNDLE}" '.[$bundle].transport' "${HARNESSES_CFG}")"

common=(env MOSAICO_CONTAINER_NAME="${CONTAINER_NAME}"
  MOSAICO_CONTAINER_CIDFILE="${CONTAINER_CIDFILE}"
  bash containers/mosaico/run --profile "${PROFILE}")

case "${MODE}" in
  direct)
    cmd=("${common[@]}" "${BACKEND_CMD}" "$@")
    ;;
  smoke)
    if [[ "${TRANSPORT}" != "acp" && "${TRANSPORT}" != "app-server" ]]; then
      echo "smoke mode requires an ACP/app-server profile, got ${PROFILE} (${TRANSPORT})" >&2
      exit 2
    fi
    cmd=("${common[@]}" mosaico __acp-smoke "${BUNDLE}" "$@")
    ;;
  launch)
    launch_args=(agents "${AGENT_SLUG}")
    if [[ -n "${MOSAICO_DEV_PROMPT:-}" ]]; then
      launch_args+=("${MOSAICO_DEV_PROMPT}")
    fi
    if [[ $# -gt 0 ]]; then
      echo "launch mode does not accept provider arguments; put operational args in the harness bundle" >&2
      exit 2
    fi
    if [[ "${TRANSPORT}" == "acp" || "${TRANSPORT}" == "app-server" ]]; then
      cmd=("${common[@]}" mosaico-hosted "${launch_args[@]}")
    else
      cmd=("${common[@]}" mosaico "${launch_args[@]}")
    fi
    ;;
  *)
    echo "unknown mode: ${MODE}" >&2
    exit 2
    ;;
esac

echo "agent_session=${SESSION} profile=${PROFILE} agent=${AGENT_SLUG} bundle=${BUNDLE} transport=${TRANSPORT} mode=${MODE}"
printf 'command='
quote_cmd "${cmd[@]}"
printf '\n'
cd "${REPO_ROOT}"
exec "${cmd[@]}"
