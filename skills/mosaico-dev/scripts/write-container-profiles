#!/usr/bin/env bash
set -euo pipefail

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

need jq
need nak

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
STATE_ROOT="${MOSAICO_DEV_STATE_ROOT:-${REPO_ROOT}/.container-state}"
ENV_FILE="${1:-${MOSAICO_DEV_ENV:-}}"
if [[ -z "${ENV_FILE}" || ! -f "${ENV_FILE}" ]]; then
  echo "usage: $0 <lab.env> [profile ...]" >&2
  exit 2
fi
shift || true
# shellcheck source=/dev/null
source "${ENV_FILE}"

if [[ $# -gt 0 ]]; then
  PROFILES=("$@")
else
  PROFILES=(claude)
fi

KEY_DIR="${WORK_DIR}/keys"
mkdir -p "${KEY_DIR}"

profile_contract() {
  local profile="$1"
  AGENT_PROFILE=
  case "${profile}" in
    claude)
      AGENT_SLUG=claude
      BUNDLE=claude
      HARNESS=claude-code
      TRANSPORT=pty
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_CLAUDE_ARGS_JSON:-[]}"
      ;;
    claude-acp)
      AGENT_SLUG=claude
      BUNDLE=claude-acp
      HARNESS=claude-code
      TRANSPORT=acp
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_CLAUDE_ACP_ARGS_JSON:-[]}"
      ;;
    codex)
      AGENT_SLUG=codex
      BUNDLE=codex
      HARNESS=codex
      TRANSPORT=pty
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_CODEX_ARGS_JSON:-[]}"
      ;;
    codex-app-server)
      AGENT_SLUG=codex
      BUNDLE=codex-app-server
      HARNESS=codex
      TRANSPORT=app-server
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_CODEX_APP_SERVER_ARGS_JSON:-[]}"
      AGENT_PROFILE="${MOSAICO_DEV_CODEX_CONFIG_PROFILE:-}"
      ;;
    grok)
      AGENT_SLUG=grok
      BUNDLE=grok
      HARNESS=grok
      TRANSPORT=pty
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_GROK_ARGS_JSON:-[]}"
      ;;
    opencode)
      AGENT_SLUG=opencode
      BUNDLE=opencode
      HARNESS=opencode
      TRANSPORT=pty
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_OPENCODE_ARGS_JSON:-[]}"
      ;;
    opencode-acp)
      AGENT_SLUG=opencode
      BUNDLE=opencode-acp
      HARNESS=opencode
      TRANSPORT=acp
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_OPENCODE_ACP_ARGS_JSON:-[]}"
      ;;
    codex-ollama)
      AGENT_SLUG=codex
      BUNDLE=codex-ollama
      HARNESS=codex
      TRANSPORT=pty
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_CODEX_OLLAMA_ARGS_JSON:-[\"--oss\",\"--local-provider\",\"ollama\"]}"
      ;;
    opencode-ollama)
      AGENT_SLUG=opencode
      BUNDLE=opencode-ollama
      HARNESS=opencode
      TRANSPORT=pty
      default_opencode_args="$(jq -cn --arg model \
        "${MOSAICO_DEV_OPENCODE_OLLAMA_MODEL:-ollama/deepseek-r1:8b}" \
        '["-m",$model]')"
      BUNDLE_ARGS_JSON="${MOSAICO_DEV_OPENCODE_OLLAMA_ARGS_JSON:-${default_opencode_args}}"
      ;;
    *)
      printf 'unsupported profile %s; expected claude|claude-acp|codex|codex-app-server|grok|opencode|opencode-acp|codex-ollama|opencode-ollama\n' "${profile}" >&2
      exit 2
      ;;
  esac
  if ! jq -e 'type == "array" and all(.[]; type == "string")' \
    <<<"${BUNDLE_ARGS_JSON}" >/dev/null; then
    printf 'invalid args JSON for profile %s: expected an array of strings\n' "${profile}" >&2
    exit 2
  fi
}

reset_mosaico_state() {
  local state_dir="$1" mosaico_dir="${1}/mosaico"
  if [[ "${MOSAICO_DEV_RESET_PROFILE_STATE:-1}" != "1" ]]; then
    mkdir -p "${mosaico_dir}"
    return 0
  fi
  chmod -R u+w "${mosaico_dir}" 2>/dev/null || true
  rm -rf "${mosaico_dir}"
  mkdir -p "${mosaico_dir}"
}

if [[ -z "${OWNER_SK_FILE:-}" || ! -s "${OWNER_SK_FILE}" ]]; then
  echo "lab environment is missing OWNER_SK_FILE; start the relay first" >&2
  exit 2
fi
OWNER_SECRET="$(<"${OWNER_SK_FILE}")"
OWNER_PUBKEY="$(nak key public "${OWNER_SECRET}")"

declare -a BACKEND_PUBKEYS=()
for profile in "${PROFILES[@]}"; do
  profile_contract "${profile}"
  backend_key_file="${KEY_DIR}/${profile}.nsec"
  if [[ ! -s "${backend_key_file}" ]]; then
    nak key generate >"${backend_key_file}"
    chmod 600 "${backend_key_file}"
  fi
  BACKEND_PUBKEYS+=("$(nak key public "$(<"${backend_key_file}")")")
done

whitelist_json="$(jq -cn --arg public "${OWNER_PUBKEY}" '[$public]')"

for i in "${!PROFILES[@]}"; do
  profile="${PROFILES[$i]}"
  profile_contract "${profile}"
  backend_key_file="${KEY_DIR}/${profile}.nsec"
  state_dir="${STATE_ROOT}/${profile}"
  cfg="${state_dir}/mosaico/config.json"
  mosaico_dir="${state_dir}/mosaico"
  harnesses_cfg="${mosaico_dir}/harnesses.json"
  agent_cfg="${mosaico_dir}/agents/${AGENT_SLUG}.json"
  mkdir -p "${state_dir}/mosaico" "${state_dir}/home"
  reset_mosaico_state "${state_dir}"
  mkdir -p "${mosaico_dir}/agents"
  jq -n \
    --argjson whitelisted "${whitelist_json}" \
    --arg relay "${RELAY_WS}" \
    --arg backend "${profile}" \
    --rawfile user_secret "${OWNER_SK_FILE}" \
    --rawfile backend_secret "${backend_key_file}" \
    '{
      whitelistedPubkeys: $whitelisted,
      relays: [$relay],
      indexerRelay: $relay,
      backendName: $backend,
      userNsec: ($user_secret | rtrimstr("\n")),
      mosaicoPrivateKey: ($backend_secret | rtrimstr("\n"))
    }' >"${cfg}"

  jq -n \
    --arg bundle "${BUNDLE}" \
    --arg harness "${HARNESS}" \
    --arg transport "${TRANSPORT}" \
    --argjson args "${BUNDLE_ARGS_JSON}" \
    '{($bundle): ({harness:$harness,transport:$transport}
      + if $args == [] then {} else {args:$args} end)}' \
    >"${harnesses_cfg}"

  jq -n \
    --arg slug "${AGENT_SLUG}" \
    --argjson created_at "$(date +%s)" \
    --arg harness "${BUNDLE}" \
    --arg profile "${AGENT_PROFILE}" \
    '{slug:$slug,created_at:$created_at,perSessionKey:true,harness:$harness}
      + if $profile == "" then {} else {profile:$profile} end' \
    >"${agent_cfg}"

  jq -e . "${cfg}" "${harnesses_cfg}" "${agent_cfg}" >/dev/null
  chmod 600 "${cfg}" "${agent_cfg}"
  echo "profile=${profile} agent=${AGENT_SLUG} bundle=${BUNDLE} harness=${HARNESS} transport=${TRANSPORT} config=${cfg} human_pubkey=${OWNER_PUBKEY:0:12} backend_pubkey=${BACKEND_PUBKEYS[$i]:0:12} reset_mosaico_state=${MOSAICO_DEV_RESET_PROFILE_STATE:-1}"
done
