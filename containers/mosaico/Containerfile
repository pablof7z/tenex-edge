FROM golang:1-bookworm AS nak-builder

RUN go install github.com/fiatjaf/nak@latest

FROM node:22-bookworm AS node-runtime

FROM rust:1-bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        iproute2 \
        jq \
        lsof \
        pkg-config \
        sqlite3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=nak-builder /go/bin/nak /usr/local/bin/nak
COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN ln -s ../lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -s ../lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

RUN mkdir -p /opt/opencode \
    && npm install --prefix /opt/opencode --no-bin-links opencode-ai \
    && printf '#!/usr/bin/env bash\nexec /opt/opencode/node_modules/opencode-ai/bin/opencode.exe "$@"\n' > /usr/local/bin/opencode \
    && chmod +x /usr/local/bin/opencode

RUN mkdir -p /opt/codex \
    && npm install --prefix /opt/codex --no-bin-links @openai/codex \
    && printf '#!/usr/bin/env bash\nexec /opt/codex/node_modules/@openai/codex/bin/codex.js "$@"\n' > /usr/local/bin/codex \
    && chmod +x /usr/local/bin/codex

RUN mkdir -p /opt/claude \
    && npm install --prefix /opt/claude --no-bin-links @anthropic-ai/claude-code \
    && printf '#!/usr/bin/env bash\nexec /opt/claude/node_modules/@anthropic-ai/claude-code/bin/claude.exe "$@"\n' > /usr/local/bin/claude \
    && chmod +x /usr/local/bin/claude

# The runtime's Claude ACP driver invokes this adapter through npx. Install it
# in the image so a fresh live-lab profile never pauses for an interactive npx
# download before the JSON-RPC handshake.
RUN npm install --global @agentclientprotocol/claude-agent-acp

ARG GROK_VERSION=0.2.102
RUN curl -fsSL https://x.ai/cli/install.sh \
    | HOME=/opt/grok GROK_BIN_DIR=/usr/local/bin bash -s "${GROK_VERSION}"

ARG GOOSE_VERSION=1.43.0
ARG TARGETARCH=arm64
RUN case "${TARGETARCH}" in \
      arm64) goose_arch=aarch64 ;; \
      amd64) goose_arch=x86_64 ;; \
      *) echo "unsupported Goose architecture: ${TARGETARCH}" >&2; exit 2 ;; \
    esac \
    && curl -fsSL \
      "https://github.com/aaif-goose/goose/releases/download/v${GOOSE_VERSION}/goose-${goose_arch}-unknown-linux-gnu.tar.gz" \
      | tar -xzf - -C /usr/local/bin ./goose \
    && chmod +x /usr/local/bin/goose

# Grok's terminal tool starts a login shell that may replace PATH. Keep the
# profile-local build reachable at a stable system path for injected commands.
RUN printf '#!/usr/bin/env bash\nexec /state/target/debug/mosaico "$@"\n' \
      > /usr/local/bin/mosaico \
    && chmod +x /usr/local/bin/mosaico

WORKDIR /workspace

ENV HOME=/state/home \
    XDG_CONFIG_HOME=/state/home/.config \
    XDG_CACHE_HOME=/state/home/.cache \
    XDG_DATA_HOME=/state/home/.local/share \
    XDG_STATE_HOME=/state/home/.local/state \
    CARGO_HOME=/state/cargo \
    CARGO_TARGET_DIR=/state/target \
    CODEX_HOME=/state/home/.codex \
    GROK_HOME=/state/home/.grok \
    GOOSE_DISABLE_KEYRING=1 \
    MOSAICO_CONFIG=/state/mosaico/config.json \
    MOSAICO_HOME=/state/mosaico \
    MOSAICO_BIN=/state/target/debug/mosaico \
    PATH=/state/target/debug:/usr/local/cargo/bin:/usr/local/bin:/usr/bin:/bin

CMD ["bash"]
