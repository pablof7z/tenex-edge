#!/usr/bin/env bash
set -euo pipefail

PROFILE="${1:?missing profile}"
HOST_AUTH="${2:?missing host-auth mode}"
AGENT="${MOSAICO_AGENT:?missing MOSAICO_AGENT}"

validate_mosaico_configs() {
  if [[ ! -f "${MOSAICO_HOME}/harnesses.json" ]]; then
    echo "harness bundles: none"
    return 0
  fi
  jq -e '
    type == "object" and
    all(.[];
      type == "object" and
      ((keys - ["args", "harness", "transport"]) | length == 0) and
      (.harness == "claude-code" or .harness == "codex" or
        .harness == "opencode" or .harness == "grok" or .harness == "goose" or
        .harness == "hermes") and
      (.transport == "pty" or .transport == "acp" or
        .transport == "app-server") and
      ((.args // []) | type == "array") and
      all((.args // [])[]; type == "string")
    )
  ' "${MOSAICO_HOME}/harnesses.json" >/dev/null
  for agent_file in "${MOSAICO_HOME}"/agents/*.json; do
    [[ -e "${agent_file}" ]] || continue
    jq -e '
      type == "object" and
      ((keys - ["byline", "created_at", "harness", "perSessionKey", "profile",
        "public_key", "secret_key", "slug"]) | length == 0) and
      (.slug | type == "string" and length > 0) and
      (.harness | type == "string" and length > 0) and
      (.created_at | type == "number") and
      ((.byline == null) or (.byline | type == "string")) and
      ((.profile == null) or (.profile | type == "string" and length > 0)) and
      ((.perSessionKey // true) | type == "boolean") and
      (if (.perSessionKey // true) then
        ((has("secret_key") or has("public_key")) | not)
      else
        (.secret_key | type == "string" and length > 0) and
        (.public_key | type == "string" and length > 0)
      end)
    ' "${agent_file}" >/dev/null
  done
  echo "harness bundles: $(jq -r 'keys | join(",")' "${MOSAICO_HOME}/harnesses.json")"
}

if [[ "${MOSAICO_DOCTOR_CONFIG_ONLY:-0}" == "1" ]]; then
  validate_mosaico_configs
  exit 0
fi

echo "profile: ${PROFILE}"
echo "agent: ${AGENT}"
echo "rust: $(rustc --version)"
echo "cargo: $(cargo --version)"
echo "claude: $(claude --version)"
echo "codex: $(codex --version)"
echo "grok: $(grok --version)"
echo "goose: $(goose --version)"
echo "hermes: $(hermes --version | head -1)"
echo "opencode: $(opencode --version)"
echo "node: $(node --version)"
echo "claude-acp-adapter: $(command -v claude-agent-acp)"
codex app-server --help >/dev/null 2>&1
opencode acp --help >/dev/null 2>&1
goose acp --help >/dev/null 2>&1
hermes acp --check >/dev/null 2>&1
echo "rpc harnesses: claude acp adapter, codex app-server, opencode acp, goose acp, hermes acp"
echo "nak: $(nak --version 2>/dev/null | head -1)"
echo "ollama_host: ${OLLAMA_HOST}"
echo "host_auth: ${HOST_AUTH}"

test -f /workspace/Cargo.toml
echo "source: /workspace mounted"
if touch /workspace/.container-readonly-check 2>/dev/null; then
  rm -f /workspace/.container-readonly-check
  echo "source: writable (unexpected)"
  exit 1
fi
touch /state/write-check
rm /state/write-check
echo "state: /state writable"

case "${AGENT}" in
  claude)
    test -s "${HOME}/.claude.json"
    jq -e 'has("oauthAccount")' "${HOME}/.claude.json" >/dev/null
    test -s "${CLAUDE_CONFIG_DIR}/.claude.json"
    jq -e 'has("oauthAccount")' "${CLAUDE_CONFIG_DIR}/.claude.json" >/dev/null
    test -s "${CLAUDE_CONFIG_DIR}/.credentials.json"
    jq -e '.claudeAiOauth.accessToken and .claudeAiOauth.refreshToken' \
      "${CLAUDE_CONFIG_DIR}/.credentials.json" >/dev/null
    HARNESS=claude-code
    ;;
  codex)
    test -f "${CODEX_HOME}/auth.json"
    HARNESS=codex
    ;;
  grok)
    test -s "${GROK_HOME}/auth.json"
    HARNESS=grok
    ;;
  goose)
    test -s "${XDG_CONFIG_HOME}/goose/config.yaml"
    test -s "${XDG_CONFIG_HOME}/goose/secrets.yaml"
    jq -e 'type == "object"' "${XDG_CONFIG_HOME}/goose/secrets.yaml" >/dev/null
    HARNESS=goose
    ;;
  hermes)
    test -s "${HERMES_HOME}/config.yaml"
    HERMES_PROFILE="$(
      jq -r '.profile // empty' "${MOSAICO_HOME}/agents/hermes.json" 2>/dev/null || true
    )"
    if [[ -n "${HERMES_PROFILE}" ]]; then
      test -s "${HERMES_HOME}/profiles/${HERMES_PROFILE}/config.yaml"
      HERMES_PROVIDER="$(
        hermes --profile "${HERMES_PROFILE}" config get model.provider
      )"
      [[ -n "${HERMES_PROVIDER}" && "${HERMES_PROVIDER}" != "auto" ]]
      hermes --profile "${HERMES_PROFILE}" auth status "${HERMES_PROVIDER}" \
        | grep -Fq 'logged in'
      echo "hermes profile auth: ${HERMES_PROFILE} (${HERMES_PROVIDER})"
    fi
    HARNESS=hermes
    ;;
  opencode)
    test -f "${XDG_DATA_HOME}/opencode/auth.json"
    HARNESS=opencode
    ;;
  *)
    echo "unsupported doctor agent: ${AGENT}" >&2
    exit 2
    ;;
esac

cargo build >/dev/null
if [[ "${AGENT}" == "goose" ]]; then
  echo "goose auth/config: staged"
else
  mosaico install --harness "${HARNESS}" >/dev/null
  case "${AGENT}" in
    claude) test -f "${HOME}/.claude/settings.json" ;;
    codex) test -f "${CODEX_HOME}/hooks.json" ;;
    grok) test -f "${GROK_HOME}/hooks/mosaico.json" ;;
    hermes)
      test -f "${HERMES_HOME}/plugins/mosaico/plugin.yaml"
      test -f "${HERMES_HOME}/plugins/mosaico/__init__.py"
      hermes plugins list --enabled --json \
        | jq -e 'any(.[]; .key == "mosaico" or .name == "mosaico")' >/dev/null
      ;;
    opencode) test -f "${XDG_CONFIG_HOME}/opencode/plugin/mosaico.ts" ;;
  esac
  echo "${AGENT} auth/hooks: mounted"
fi

validate_mosaico_configs

echo "codex home: ${CODEX_HOME}"
echo "grok home: ${GROK_HOME}"
echo "hermes home: ${HERMES_HOME}"
echo "mosaico home: ${MOSAICO_HOME}"
